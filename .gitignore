.vscode/
.idea/
.DS_Store
.mcp.json

# Presentations
*.pptx

# Logs and databases
*.log

# Datasets and ML Models
backend/ml/data/
*.csv
*.zip
*.joblib
*.pkl
# EXCEPTION: the production model loaded by ml/src/predict.py (_get_history_model)
# MUST be versioned with the code that loads it — otherwise prod has no Tier-A
# model and silently degrades to a lower tier. Orphaned/experimental .joblib
# files (xgb_repeat_v1, xgb_residual_v2, ridge_v1, xgb_v1) stay ignored.
!backend/ml/models/xgb_history_v1.joblib

# Scratch / temporary work — never commit
scratch/

# GPX/FIT files (excluding test fixtures and reference race routes)
# Reference race routes (Berlin/London/Tokyo/etc.) live in backend/data/gpx/
# and are needed on every deploy — they're public, static, ~1.5 MB total.
# User-uploaded custom GPX still lands under backend/data/gpx/custom/<uuid>/
# and stays ignored via the *.gpx fall-through.
*.gpx
*.fit
!backend/tests/fixtures/
!backend/data/gpx/*.gpx

# Design and Documentation
design-*/
docs/
EnduranceAI_TZ.md
EnduranceAI_TZ_v3.md
opus_audit_stages_1_2.md
